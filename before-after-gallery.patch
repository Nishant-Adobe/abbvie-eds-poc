+/* --- Before After Gallery Block --- */
+
+.before-after-gallery-heading {
+  margin-bottom: var(--spacing-8, 8px);
+}
+
+.before-after-gallery-description {
+  margin-bottom: var(--spacing-16, 16px);
+}
+
+/* --- Tab bar --- */
+
+.before-after-gallery-tabs {
+  display: flex;
+  gap: var(--spacing-8, 8px);
+  margin-bottom: var(--spacing-16, 16px);
+}
+
+.before-after-gallery-tab {
+  background: var(--color-light-bg, #f5f5f5);
+  border: 2px solid var(--color-border, #ccc);
+  border-radius: 4px;
+  color: var(--color-text, inherit);
+  cursor: pointer;
+  font-size: var(--body-font-size-s, 0.875rem);
+  font-weight: 600;
+  padding: var(--spacing-8, 8px) var(--spacing-16, 16px);
+  transition: background 200ms, border-color 200ms;
+}
+
+.before-after-gallery-tab.is-active {
+  background: var(--color-primary, #071d49);
+  border-color: var(--color-primary, #071d49);
+  color: var(--color-text-inverse, #fff);
+}
+
+.before-after-gallery-tab:focus-visible {
+  outline: 2px solid var(--color-focus, #0057cc);
+  outline-offset: 2px;
+}
+
+/* --- Toggle variant (pill buttons) --- */
+
+.before-after-gallery-toggle .before-after-gallery-tab {
+  border-radius: 999px;
+  flex: 1;
+  text-align: center;
+}
+
+/* --- Slider container --- */
+
+.before-after-gallery-slider {
+  --compare-position: 50%;
+
+  position: relative;
+  overflow: hidden;
+  user-select: none;
+  cursor: col-resize;
+  touch-action: none;
+  margin-bottom: var(--spacing-16, 16px);
+}
+
+/* --- After image (base layer, full width) --- */
+
+.before-after-gallery-after {
+  display: block;
+  line-height: 0;
+}
+
+.before-after-gallery-after img {
+  width: 100%;
+  height: auto;
+  display: block;
+}
+
+/* --- Before image (clipped overlay) --- */
+
+.before-after-gallery-before {
+  position: absolute;
+  inset: 0;
+  overflow: hidden;
+  width: var(--compare-position);
+}
+
+.before-after-gallery-before img {
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+  object-position: left;
+  display: block;
+}
+
+/* --- Drag handle --- */
+
+.before-after-gallery-handle {
+  position: absolute;
+  top: 0;
+  bottom: 0;
+  left: var(--compare-position);
+  transform: translateX(-50%);
+  width: 4px;
+  background-color: var(--gallery-handle-color, #fff);
+  cursor: col-resize;
+  z-index: 2;
+}
+
+.before-after-gallery-handle::before {
+  content: '';
+  position: absolute;
+  top: 50%;
+  left: 50%;
+  transform: translate(-50%, -50%);
+  width: 44px;
+  height: 44px;
