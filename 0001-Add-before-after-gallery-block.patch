+
+/* --- Before/After labels --- */
+
+.before-after-gallery-labels {
+  position: absolute;
+  bottom: var(--spacing-12, 12px);
+  left: 0;
+  right: 0;
+  display: flex;
+  justify-content: space-between;
+  padding: 0 var(--spacing-12, 12px);
+  pointer-events: none;
+  z-index: 1;
+}
+
+.before-after-gallery-label-before,
+.before-after-gallery-label-after {
+  background: rgb(0 0 0 / 60%);
+  color: #fff;
+  font-size: var(--body-font-size-xs, 0.75rem);
+  font-weight: 700;
+  letter-spacing: 0.05em;
+  padding: 4px 10px;
+  border-radius: 2px;
+  text-transform: uppercase;
+}
+
+/* --- Drag prompt overlay --- */
+
+.before-after-gallery-prompt {
+  position: absolute;
+  top: 50%;
+  left: 50%;
+  transform: translate(-50%, -50%);
+  background: rgb(0 0 0 / 70%);
+  color: #fff;
+  font-size: var(--body-font-size-s, 0.875rem);
+  font-weight: 600;
+  padding: var(--spacing-8, 8px) var(--spacing-16, 16px);
+  border-radius: 4px;
+  pointer-events: none;
+  z-index: 3;
+  transition: opacity 400ms;
+}
+
+.before-after-gallery-prompt.is-hidden {
+  opacity: 0;
+}
+
+/* --- Thumbnail grid --- */
+
+.before-after-gallery-thumbnails {
+  display: grid;
+  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
+  gap: var(--spacing-8, 8px);
+  margin-bottom: var(--spacing-16, 16px);
+}
+
+.before-after-gallery-thumb {
+  position: relative;
+  border: 3px solid transparent;
+  border-radius: 4px;
+  cursor: pointer;
+  overflow: hidden;
+  padding: 0;
+  background: none;
+  transition: border-color 200ms;
+}
+
+.before-after-gallery-thumb.is-active {
+  border-color: var(--color-primary, #071d49);
+}
+
+.before-after-gallery-thumb:focus-visible {
+  outline: 2px solid var(--color-focus, #0057cc);
+  outline-offset: 2px;
+}
+
+.before-after-gallery-thumb-image {
+  width: 100%;
+  height: auto;
+  display: block;
+}
+
+.before-after-gallery-thumb-label {
+  position: absolute;
+  bottom: 0;
+  left: 0;
+  right: 0;
+  background: rgb(0 0 0 / 60%);
+  color: #fff;
+  font-size: var(--body-font-size-xs, 0.75rem);
+  font-weight: 700;
+  padding: 4px 8px;
+  text-align: center;
+}
+
+.before-after-gallery-thumb-sublabel {
+  position: absolute;
+  bottom: 22px;
+  left: 0;
+  right: 0;
+  background: rgb(0 0 0 / 40%);
+  color: #fff;
+  font-size: 0.625rem;
+  padding: 2px 8px;
+  text-align: center;
+}
+
+/* --- Mobile responsive --- */
+
+@media (width <= 600px) {
+  .before-after-gallery-tabs {
+    flex-direction: column;
+  }
+
+  .before-after-gallery-thumbnails {
+    grid-template-columns: repeat(2, 1fr);
+  }
+
+  .before-after-gallery-handle::before {
+    width: 44px;
+    height: 44px;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .before-after-gallery-prompt {
+    transition: none;
+  }
+
+  .before-after-gallery-tab {
+    transition: none;
+  }
+
+  .before-after-gallery-thumb {
+    transition: none;
+  }
+}
+
+/* Rinvoq before-after-gallery overrides */
