{
  "definitions": [
    {
      "title": "Demo Brand Explorer",
      "id": "demo-brand-explorer",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Demo Brand Explorer",
              "model": "demo-brand-explorer",
              "filter": "demo-brand-explorer",
              "blockId": "id:"
            }
          }
        }
      }
    },
    {
      "title": "Brand Entry",
      "id": "demo-brand-explorer-brand",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Brand Entry",
              "model": "demo-brand-explorer-brand",
              "brandName": "Brand Name",
              "brandUrl": "https://example.com"
            }
          }
        }
      }
    },
    {
      "title": "Indication Link",
      "id": "demo-brand-explorer-indication",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Indication Link",
              "model": "demo-brand-explorer-indication",
              "indicationName": "Indication Name",
              "indicationUrl": "https://example.com"
            }
          }
        }
      }
    }
  ],
