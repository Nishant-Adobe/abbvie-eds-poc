+      ]
+    },
+    {
+      "id": "demo-brand-explorer-item",
+      "fields": [
+        {
+          "component": "tab",
+          "label": "Brand",
+          "name": "brand"
+        },
+        {
+          "component": "reference",
+          "valueType": "string",
+          "name": "logo",
+          "label": "Brand Logo",
+          "description": "Brand product logo image.",
+          "multi": false
+        },
+        {
+          "component": "text",
+          "valueType": "string",
+          "name": "logoAlt",
+          "value": "",
+          "label": "Logo Alt Text"
+        },
+        {
+          "component": "text",
+          "valueType": "string",
+          "name": "brandName",
+          "value": "",
+          "label": "Brand Name"
+        },
+        {
+          "component": "richtext",
+          "valueType": "string",
+          "name": "safetyText",
+          "value": "",
+          "label": "Safety Text",
+          "description": "Optional safety disclaimer text shown under the brand logo."
+        },
+        {
+          "component": "text",
+          "valueType": "string",
+          "name": "brandUrl",
+          "value": "",
+          "label": "Brand URL",
+          "description": "Link destination for this brand."
+        }
+      ]
+    }
+  ],
+  "filters": [
+    {
+      "id": "demo-brand-explorer",
+      "components": ["demo-brand-explorer-item"]
+    }
+  ]
+}
